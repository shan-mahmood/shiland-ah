# Copy to .env and fill in. All PUBLIC_* vars are exposed to the client bundle.

# Turn on GA4/GTM. Leave unset on staging so preview traffic doesn't pollute
# production analytics. Set to "on" at cutover.
PUBLIC_ANALYTICS=

# Formspree form id (the part after /f/ in your endpoint). Contact form posts here.
PUBLIC_FORMSPREE_ID=

# Online booking / client portal. Defaults to the Great Pet Care portal
# (set in src/data/site.ts); override here only to point elsewhere.
BOOK_URL=
