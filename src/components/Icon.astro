---
/**
 * Inline SVG line-icon set — lifted from the homepage's icon style.
 * Stroke-based, currentColor. No emoji, no bubble icons.
 * Google is the one exception (brand multi-color mark).
 *
 * Usage: <Icon name="phone" size={16} class="i" />
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: cls } = Astro.props;

// Stroke line-icons: path/shape markup keyed by name.
const line: Record<string, string> = {
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>',
  pin:
    '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  mail:
    '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  calendar:
    '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
  moon: '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>',
  bolt: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  arrow:
    '<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>',
  flask:
    '<path d="M9 3h6"/><path d="M10 3v6l-5 8a2 2 0 0 0 1.7 3h10.6a2 2 0 0 0 1.7-3l-5-8V3"/><path d="M7 14h10"/>',
  pulse: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  stethoscope:
    '<path d="M4 3v5a5 5 0 0 0 10 0V3"/><path d="M4 3H2"/><path d="M14 3h2"/><path d="M9 18a6 6 0 0 0 6 0"/><path d="M15 18v-2a5 5 0 0 1 5-5"/><circle cx="20" cy="9" r="2"/>',
  shield:
    '<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 12 2 2 4-4"/>',
  scalpel:
    '<path d="M14 4l6 6L9 21H3v-6z"/><path d="M14 4l-4 4"/><path d="M8 16l3-3"/>',
  tooth:
    '<path d="M12 5.5C10.5 4 8 3.5 6.5 4.8 4.5 6.5 4 10 5 14c.6 2.5.9 6 2.5 6s1.3-4 2.5-4 1 4 2.5 4 1.9-3.5 2.5-6c1-4 .5-7.5-1.5-9.2C14.5 3.5 13.5 4 12 5.5z"/>',
  xray:
    '<rect x="4" y="3" width="16" height="18" rx="2"/><path d="M12 7v10"/><path d="M9 9c2 1 4 1 6 0"/><path d="M9 15c2-1 4-1 6 0"/>',
  chip:
    '<rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2"/>',
  paw:
    '<circle cx="8" cy="9" r="1.6"/><circle cx="16" cy="9" r="1.6"/><circle cx="5.5" cy="13" r="1.4"/><circle cx="18.5" cy="13" r="1.4"/><path d="M12 13c-2.5 0-4.5 2-4.5 4 0 1.5 1.5 2 3 1.6 1-.3 2-.3 3 0 1.5.4 3-.1 3-1.6 0-2-2-4-4.5-4z"/>',
  heart:
    '<path d="M20.8 5.6a5 5 0 0 0-7.1 0L12 7.3l-1.7-1.7a5 5 0 1 0-7.1 7.1l1.7 1.7L12 21.5l7.1-7.1 1.7-1.7a5 5 0 0 0 0-7.1z"/>',
  sparkle:
    '<path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9z"/><path d="M19 15l.7 1.8L21.5 17l-1.8.7L19 19.5l-.7-1.8L16.5 17l1.8-.7z"/>',
  dove:
    '<path d="M16 7c3 0 5 2 5 2s-1 4-5 5c-3 .8-5 3-6 5-1-3-4-5-7-5 0-3 2-6 6-6 0 0 1-3 4-3 2 0 3 1 3 1z"/><circle cx="17" cy="6" r="0.6"/>',
  gift:
    '<rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7"/><path d="M12 8C12 8 11 3 8 3a2.5 2.5 0 0 0 0 5z"/><path d="M12 8s1-5 4-5a2.5 2.5 0 0 1 0 5z"/>',
  device:
    '<rect x="7" y="2" width="10" height="20" rx="2"/><line x1="11" y1="18" x2="13" y2="18"/>',
};

const isGoogle = name === 'google';
const markup = line[name] ?? line.paw;
---

{isGoogle ? (
  <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true" class={cls}>
    <path fill="#4285F4" d="M23.5 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.5c-.3 1.5-1.1 2.7-2.4 3.6v3h3.9c2.3-2.1 3.5-5.2 3.5-8.8z"/>
    <path fill="#34A853" d="M12 24c3.2 0 5.9-1.1 7.9-2.9l-3.9-3c-1.1.7-2.4 1.2-4 1.2-3.1 0-5.7-2.1-6.6-4.9H1.4v3.1C3.4 21.3 7.4 24 12 24z"/>
    <path fill="#FBBC05" d="M5.4 14.4c-.2-.7-.4-1.4-.4-2.4s.1-1.7.4-2.4V6.5H1.4C.5 8.2 0 10 0 12s.5 3.8 1.4 5.5l4-3.1z"/>
    <path fill="#EA4335" d="M12 4.8c1.8 0 3.3.6 4.6 1.8l3.4-3.4C17.9 1.2 15.2 0 12 0 7.4 0 3.4 2.7 1.4 6.5l4 3.1C6.3 6.9 8.9 4.8 12 4.8z"/>
  </svg>
) : (
  <svg
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke="currentColor"
    stroke-width="1.7"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    class={cls}
    set:html={markup}
  />
)}
